# ==========================================
# Application
# ==========================================
APP_NAME=Predictive User Behavior Analytics API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

# ==========================================
# Server
# ==========================================
HOST=0.0.0.0
PORT=8000

# ==========================================
# Security
# ==========================================
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# Database
# SQLite (MVP)
# ==========================================
DATABASE_URL=sqlite:///./user_behavior.db

# ==========================================
# CORS
# ==========================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==========================================
# Machine Learning
# ==========================================
MODEL_PATH=models/user_behavior_model.joblib

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# Render
# ==========================================
RENDER=false
